{% extends "base.njk" %}

{% block title %}{{ producto.título | trim }} — Tienda Prado{% endblock %}

{% block content %}

  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb" class="mt-3 mb-4">
    <ol class="breadcrumb" style="font-size:0.8rem; background:none; padding:0">
      <li class="breadcrumb-item"><a href="/" class="text-dark">Inicio</a></li>
      <li class="breadcrumb-item"><a href="/" class="text-dark">Impresiones</a></li>
      <li class="breadcrumb-item active text-muted">{{ producto.título | trim }}</li>
    </ol>
  </nav>

  <div class="row g-5 mb-5">

    <!-- Product image -->
    <div class="col-md-6">
      <div style="background:#f8f8f8; padding:20px">
        <img
          src="/public/imagenes/{{ producto.imagen | trim }}"
          alt="{{ producto.título | trim }}"
          class="img-fluid"
          style="width:100%; object-fit:contain; max-height:480px"
          onerror="this.src='https://placehold.co/500x500?text=Sin+imagen'"
        >
      </div>
    </div>

    <!-- Product info -->
    <div class="col-md-6">
      <h1 style="font-family:'EB Garamond',serif; font-size:1.7rem; font-weight:400; line-height:1.3">
        {{ producto.título | trim }}
      </h1>

      <div class="mt-3 mb-4" style="font-size:0.9rem; color:#555; white-space:pre-line; line-height:1.7">
        {{ producto.descripción }}
      </div>

      <div style="font-size:1.4rem; font-weight:400; color:#333; margin-bottom:1.5rem">
        {{ producto.precio }} €
      </div>

      <div class="d-flex align-items-center gap-3">
        <input
          type="number"
          value="1"
          min="1"
          class="form-control"
          style="width:75px; border-radius:0; border-color:#ccc"
        >
        <button
          class="btn px-4 py-2"
          style="background:#4a4a4a; color:#fff; border-radius:0; font-size:0.85rem; letter-spacing:0.05em"
        >
          Añadir a la cesta
        </button>
      </div>
    </div>

  </div>
{% endblock %}